       <property name="styleSheet">
        <string notr="true">QPushButton {


;
background-color: rgb(0, 85, 127);
border-radius:5px;
padding: 7px 0;
color: white;
border: 1px solid WHITE;
}

QPushButton:hover {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffffcc,  /* vàng trắng nhạt */
        stop:1 #fff176   /* vàng nhạt */
    );
    color: black;
}

QPushButton:pressed {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffb74d,  /* cam nhạt */
        stop:1 #f57c00   /* cam đậm */
    );
    color: black;

}</string>
       </property>
