       <property name="styleSheet">
        <string notr="true">QSlider#sliderGamma {
    outline: none;
    border: none;
}

QSlider::groove:horizontal {
    height: 8px;
    background: #e0e0e0;
    border-radius: 4px; 
}

QSlider::handle:horizontal {
    background: #0078D7; 
    width: 20px;  
    height: 20px;
    margin: -6px 0;
    border-radius: 10px; 
	border: none;
}

QSlider::handle:horizontal:hover {
    background: #005A9E;
}</string>
